#!/bin/bash
# opentty - Open files/folders in Ghostty via AppleScript API (1.3.0+)
# Reuses existing Ghostty window (new tab), or creates a new window if none exists.

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opentty/config"

# Defaults
OPENTTY_PAGER="bat --paging=always"

# Load user config
if [ -f "$CONFIG" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG"
fi

open_tab() {
    local dir="$1"
    shift
    local cmd="$*"

    # Use "initial input" in surface configuration to send command on launch.
    # Append newline so the command executes automatically.
    local input_line=""
    if [ -n "$cmd" ]; then
        input_line="$cmd
"
    fi

    osascript \
        -e 'on run argv' \
        -e '    set dir to item 1 of argv' \
        -e '    set inp to item 2 of argv' \
        -e '    tell application "Ghostty"' \
        -e '        set cfg to new surface configuration' \
        -e '        set initial working directory of cfg to dir' \
        -e '        if inp is not "" then' \
        -e '            set initial input of cfg to inp' \
        -e '        end if' \
        -e '        if (count of windows) > 0 then' \
        -e '            new tab in front window with configuration cfg' \
        -e '        else' \
        -e '            new window with configuration cfg' \
        -e '        end if' \
        -e '        activate' \
        -e '    end tell' \
        -e 'end run' \
        -- "$dir" "$input_line"
}

for arg in "$@"; do
    if [ -d "$arg" ]; then
        open_tab "$arg"
    elif [ -f "$arg" ]; then
        dir="$(dirname "$arg")"
        # shellcheck disable=SC2086
        open_tab "$dir" $OPENTTY_PAGER "$arg"
    fi
done

# No arguments: just open a tab in home
if [ $# -eq 0 ]; then
    open_tab "$HOME"
fi
