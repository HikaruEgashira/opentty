#!/bin/bash
# opentty - Open files/folders in Ghostty via AppleScript
# Reuses existing Ghostty window (new tab), or creates a new window if none exists.

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opentty/config"

# Defaults
OPENTTY_PAGER="bat --paging=always"

# Load user config
if [ -f "$CONFIG" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG"
fi

open_tab() {
    local dir="$1"
    shift
    local cmd="$*"

    osascript <<APPLESCRIPT
tell application "Ghostty"
    set cfg to new surface configuration
    set initial working directory of cfg to "$dir"

    if (count of windows) > 0 then
        set t to new tab in front window with configuration cfg
    else
        set win to new window with configuration cfg
        set t to terminal 1 of selected tab of win
    end if

    if "$cmd" is not "" then
        input text "$cmd" to t
        send key "enter" to t
    end if

    activate
end tell
APPLESCRIPT
}

for arg in "$@"; do
    if [ -d "$arg" ]; then
        open_tab "$arg"
    elif [ -f "$arg" ]; then
        dir="$(dirname "$arg")"
        # shellcheck disable=SC2086
        open_tab "$dir" $OPENTTY_PAGER "$arg"
    fi
done

# No arguments: just open a tab in home
if [ $# -eq 0 ]; then
    open_tab "$HOME"
fi
